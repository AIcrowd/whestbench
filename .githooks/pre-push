#!/usr/bin/env bash
# Pre-push hook: runs the same lint + quick test checks as CI.
# Install: git config core.hooksPath .githooks

set -euo pipefail

echo "==> pre-push: ruff check"
uv run ruff check .

echo "==> pre-push: ruff format --check"
uv run ruff format --check .

echo "==> pre-push: pytest (quick)"
uv run pytest -m "not exhaustive" -x -q

echo "==> pre-push: all checks passed"
