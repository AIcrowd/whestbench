Screen {
    background: #f7f5ef;
    color: #111111;
}

#dashboard-tabs {
    dock: top;
    padding: 1;
    border: solid #d6d3ce;
    background: #fffdf8;
    color: #4b5563;
    text-style: bold;
}

#dashboard-content {
    padding: 1 2;
    border: solid #d6d3ce;
    background: #fffdf8;
    color: #111111;
    overflow-y: auto;
}

Header {
    background: #fffdf8;
    color: #1d4ed8;
}

Footer {
    background: #fffdf8;
    color: #b45309;
}
